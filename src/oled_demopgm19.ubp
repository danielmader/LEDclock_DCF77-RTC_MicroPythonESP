version 1 0 
description ''
variables _imgBMPTbl _imgBMPTbl2 

	spec ' ' 'BR1' 'BR1'
	spec ' ' 'BRPIC' 'BRPIC'

to BR1 {
  comment 'Place this under P1'
  local '_imgHex' '20203C1F1F071B1B1F1B07070707070703010101010303030703030F0B0D1D157171DE00001CF0C8F8F8F8F8F8FCFCFCFEFEFEFF7E7F3F3F3F7E7CF8F8F0C00000A980818080C0030F1D3D79F8F0F8DD7F7F7FBC3C34842CBC3E3FFFFFFF7F000011010200000000000000000001033022030604080000020401010181C0E0F07C3E'
  '_process image data' _imgHex
